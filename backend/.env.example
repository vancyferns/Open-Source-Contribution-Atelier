DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Cloud database URLs. Plug in your keys here; the backend will try Supabase first,
# then Neon, and keep the local fallback if neither cloud database is reachable.
SUPABASE_DATABASE_URL=
NEON_DATABASE_URL=
DB_CONN_MAX_AGE=60

# Local PostgreSQL settings used when no cloud URL is configured.
DB_NAME=contribution_atelier
DB_USER=contribution_atelier
DB_PASSWORD=contribution_atelier
DB_HOST=db
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173
REDIS_URL=redis://127.0.0.1:6379
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
